{
  "name": "letta-code",
  "version": "0.1.0",
  "description": "Fork of letta-ai/letta-code — AI-powered coding assistant powered by Letta",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bunx eslint src --ext .ts,.tsx",
    "lint:fix": "bunx eslint src --ext .ts,.tsx --fix",
    "typecheck": "bunx tsc --noEmit",
    "format": "bunx prettier --write \"src/**/*.{ts,tsx,json}\"",
    "ci": "bun run typecheck && bun run lint && bun run test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@letta-ai/letta-client": "^0.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/me/letta-code",
    "upstream": "https://github.com/letta-ai/letta-code"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "tabWidth": 2,
    "printWidth": 100
  }
}
